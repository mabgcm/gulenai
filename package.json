{
  "name": "gulenai-ingestion",
  "version": "0.1.0",
  "description": "Generic knowledge ingestion pipeline for AI assistant source indexing.",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test": "vitest run",
    "crawl": "tsx src/cli/index.ts crawl",
    "extract": "tsx src/cli/index.ts extract",
    "markdown": "tsx src/cli/index.ts markdown",
    "chunk": "tsx src/cli/index.ts chunk",
    "embed": "tsx src/cli/index.ts embed",
    "index": "tsx src/cli/index.ts index",
    "status": "tsx src/cli/index.ts status",
    "qdrant": "tsx src/cli/index.ts qdrant",
    "search": "tsx src/cli/index.ts search",
    "prompt": "tsx src/cli/index.ts prompt",
    "answer": "tsx src/cli/index.ts answer",
    "api": "tsx src/api/index.ts",
    "diagnose": "tsx src/cli/index.ts diagnose",
    "validate-search": "tsx src/cli/index.ts validate-search",
    "inspect": "tsx src/cli/index.ts inspect",
    "crawl-report": "tsx src/cli/index.ts crawl-report",
    "reset": "tsx src/cli/index.ts reset"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/swagger": "^8.15.0",
    "@fastify/swagger-ui": "^2.1.0",
    "@mozilla/readability": "^0.6.0",
    "@qdrant/js-client-rest": "^1.13.0",
    "cheerio": "^1.0.0",
    "domhandler": "^6.0.1",
    "dotenv": "^16.4.7",
    "fastify": "^4.29.1",
    "js-tiktoken": "^1.0.21",
    "jsdom": "^24.1.3",
    "openai": "^4.77.0",
    "pino": "^9.6.0",
    "playwright": "^1.49.1",
    "turndown": "^7.2.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/jsdom": "^21.1.7",
    "@types/node": "^22.10.5",
    "@types/turndown": "^5.0.5",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.19.0",
    "vitest": "^2.1.8"
  }
}
